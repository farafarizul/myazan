{
  "name": "my-azan",
  "version": "0.1.0",
  "description": "Aplikasi azan automatik untuk Windows 10/11",
  "main": "dist/main/index.js",
  "author": {
    "name": "Fara Farizul",
    "email": "farxpeace@gmail.com"
  },
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "compile": "node scripts/build.js",
    "postinstall": "electron-builder install-app-deps",
    "start": "npm run compile && electron .",
    "dev": "concurrently -k \"node scripts/build.js --watch\" \"wait-on dist/main/index.js && electron . --dev\"",
    "typecheck": "tsc --noEmit && tsc --noEmit --project tsconfig.renderer.json",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.{ts,html,css,json}\"",
    "build": "npm run compile && electron-builder --win nsis --x64"
  },
  "devDependencies": {
    "@fontsource/inter": "^5.2.8",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "concurrently": "^9.0.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "material-symbols": "^0.44.1",
    "prettier": "^3.0.0",
    "typescript": "^6.0.2",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0"
  },
  "build": {
    "appId": "com.farafarizul.myazan",
    "productName": "myAzan",
    "copyright": "Copyright © 2026 Fara Farizul",
    "directories": {
      "output": "dist-build",
      "buildResources": "src/assets"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asar": true,
    "npmRebuild": true,
    "buildDependenciesFromSource": false,
    "forceCodeSigning": false,
    "win": {
      "icon": "src/assets/icons/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icons/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "artifactName": "${productName}-Installer-${version}.${ext}"
    }
  }
}